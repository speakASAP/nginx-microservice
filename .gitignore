*backup*
*bck*
*.bak*

# Environment variables
.env*
!.env.example

# Certificates (sensitive data)
certificates/

# Cloudflare/DNS API credentials for wildcard certs (DNS-01)
secrets/*
!secrets/.gitkeep
*.pem
*.key
*.crt

# Logs
logs/
*.log

# Webroot (Let's Encrypt challenge files)
webroot/.well-known/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.bak

# Backup and local override files (but allow actual config files)
nginx/conf.d/*.backup*
nginx/conf.d/*.local
nginx/conf.d/*.disabled

# MinIO proxy include generated by minio-microservice/scripts/deploy.sh from minio-microservice/nginx/minio.conf (do not track)
nginx/includes/minio-proxy-settings.conf

# Domain config symlinks (generated at runtime by deployment scripts)
# Blue-green config files are auto-generated by deployment scripts and should not be tracked
nginx/conf.d/*.conf
# Allow directories but ignore files inside (except .gitkeep)
nginx/conf.d/staging/*
!nginx/conf.d/staging/.gitkeep
nginx/conf.d/rejected/*
!nginx/conf.d/rejected/.gitkeep
nginx/conf.d/blue-green/*
!nginx/conf.d/blue-green/.gitkeep
# Service registry files are auto-generated by deployment scripts and should not be tracked
service-registry/*.json
!service-registry/.gitkeep
service-registry/*.backup*
service-registry/*.local

# State files (runtime deployment state - auto-generated)
state/*.json
!state/.gitkeep

# --- baseline: secrets-env-artifacts (synced across repos) ---

node_modules/
dist/
.env
.venv
.venv*
k8s/secret.yaml
# Local credential files (never commit)
secrets/
**/client_secret*.json
**/*.apps.googleusercontent.com.json
*.tsbuildinfo
# Security: Never commit keys or certificates
keys/*
!keys/README.md
*.cer
*.pfx
*.p12
*private*
*.rsa
*.dsa
*.ec
*.der
# Database files
*.db
*.sqlite
*.sqlite3
# Environments
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
# Local configuration
local_config.py
local_settings.py
# Backup files
*.backup*
*.old
# Compressed files
*.zip
*.tar.gz
*.rar
*.7z
